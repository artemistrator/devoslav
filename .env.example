# Database
DATABASE_URL="postgresql://orchestrator:orchestrator@db:5432/orchestrator?schema=public"

# OpenAI (default endpoint: https://api.openai.com/v1)
OPENAI_API_KEY=""
OPENAI_BASE_URL="" # leave empty for official API; set only for proxy/custom endpoint

# Anthropic
ANTHROPIC_API_KEY=""

# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Z.ai (GLM). Use CODING endpoint if you have GLM Coding Plan (Cursor/OpenCode subscription):
ZAI_API_KEY=""
# GLM Coding Plan (subscription) → use coding endpoint; pay-as-you-go Model API → use paas/v4
ZAI_BASE_URL="https://api.z.ai/api/coding/paas/v4"

# Tavily API for web search
TAVILY_API_KEY=""

# Default selection (optional)
AI_PROVIDER="openai"
AI_MODEL="gpt-4o-mini"

# Local development: when running on non-default port (e.g. 3002), set PORT or INTERNAL_APP_URL
# so the execution worker (triggered from /api/execution-sessions/start) can reach the app.
# PORT=3002
# INTERNAL_APP_URL="http://localhost:3002"
